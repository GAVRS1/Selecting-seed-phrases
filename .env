# PostgreSQL connection settings for recovery_tool and migrations script.
RECOVERY_POSTGRES_CONN=postgresql://timur:1234@127.0.0.1:5432/recovery
RECOVERY_POSTGRES_TABLE=recovered_wallets

# Console launch settings for run_project.bat.
# Enable or disable per-chain launch (true/false).
RECOVERY_ENABLE_BTC=true
RECOVERY_ENABLE_ETH=true
RECOVERY_ENABLE_SOL=true
RECOVERY_ENABLE_TON=false

# How many consoles to open for each chain.
# 0 means "open none" for that chain.
RECOVERY_CONSOLES_BTC=1
RECOVERY_CONSOLES_ETH=1
RECOVERY_CONSOLES_SOL=1
RECOVERY_CONSOLES_TON=0

# Run Python balance checker together with run_project.bat (true/false).
RECOVERY_RUN_BALANCE_CHECKER=true

# Proxy settings for scripts/check_wallet_balances.py only.
# Checker reads proxy list from data/proxies.txt.
RECOVERY_BALANCE_CHECKER_PROXY_ENABLED=false

# Unified checker settings (used by scripts/evm-checker and scripts/solana-checker)
POSTGRES_CONN=postgresql://timur:1234@127.0.0.1:5432/recovery
DB_FETCH_LIMIT=500
DELETE_PROCESSED_WALLETS=true
BATCH_SIZE=200
RETRY_ATTEMPTS=3
RETRY_DELAY=1000
ENABLE_LOGGING=true
ENABLE_PROGRESS_BAR=true

# Optional checker table overrides
RECOVERY_EVM_POSTGRES_SOURCE_TABLE=recovered_wallets_evm
RECOVERY_SOL_POSTGRES_SOURCE_TABLE=recovered_wallets_sol

# Data files should live in ./data
# Example: data/proxies.txt

# Optional BTC checker table override
RECOVERY_BTC_POSTGRES_SOURCE_TABLE=recovered_wallets_btc

# Bitcoin RPC URLs for scripts/bitcoin-checker
# Use URL with credentials: http://user:password@127.0.0.1:8332
BTC_RPC_URL=http://127.0.0.1:8332
# BTC_RPC_URLS=http://user:pass@127.0.0.1:8332,http://user:pass@10.0.0.2:8332
