# PostgreSQL connection settings for recovery_tool and migrations script.
RECOVERY_POSTGRES_CONN=postgresql://postgres:postgres@127.0.0.1:5432/recovery
RECOVERY_POSTGRES_TABLE=recovered_wallets

# Console launch settings for run_project.bat.
# Enable or disable per-chain launch (true/false).
RECOVERY_ENABLE_BTC=true
RECOVERY_ENABLE_ETH=true
RECOVERY_ENABLE_SOL=true
RECOVERY_ENABLE_TON=true

# How many consoles to open for each chain.
# 0 means "open none" for that chain.
RECOVERY_CONSOLES_BTC=1
RECOVERY_CONSOLES_ETH=1
RECOVERY_CONSOLES_SOL=1
RECOVERY_CONSOLES_TON=1
